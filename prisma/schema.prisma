generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tiers {
  id              String   @id @default(cuid())
  code            String   @unique
  type            String
  raisonSociale   String
  adresse         String?
  adresse2        String?
  codePostal      String?
  ville           String?
  pays            String?
  telephone       String?
  email           String?
  ice             String?
  rc              String?
  rcLieu          String?
  if              String?
  tp              String?
  cnss            String?
  infoLibre       String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  facturesClients          FactureClient[]
  facturesFournisseurs     FactureFournisseur[]
  bonsLivraison            BonLivraison[]
  avoirsClients            AvoirClient[]
}

model Article {
  id            String   @id @default(cuid())
  code          String   @unique
  designation   String
  prixUnitaire  Float    @default(0)
  unite         String    @default("pièce")
  tauxTVA       Float    @default(20)
  infoLibre     String?
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lignesFactureClient    LigneFactureClient[]
  lignesBonLivraison     LigneBonLivraison[]
  lignesAvoirClient      LigneAvoirClient[]
}

model FactureClient {
  id              String   @id @default(cuid())
  numero          String   @unique
  dateFacture     DateTime
  clientId        String
  bonCommande     String?  // Numéro de bon de commande client
  numeroBL        String?  // Numéro de BL (auto-rempli si converti depuis BL)
  dateEcheance    DateTime
  statut          String   @default("BROUILLON")
  notes           String?
  notesLivraison  String?
  infoLibre       String?
  totalHT         Float    @default(0)
  totalTVA        Float    @default(0)
  totalTTC        Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Tiers              @relation(fields: [clientId], references: [id])
  lignes          LigneFactureClient[]
  reglements      ReglementClient[]
  bonsLivraison   BonLivraison[]     // BL convertis en cette facture
  avoirs          AvoirClient[]      // Avoirs créés depuis cette facture

  @@index([clientId])
  @@index([statut])
}

model LigneFactureClient {
  id            String   @id @default(cuid())
  factureId     String
  articleId     String?
  designation   String
  quantite      Float    @default(0)
  prixUnitaire  Float    @default(0)
  tauxTVA       Float    @default(20)
  totalHT       Float    @default(0)

  facture       FactureClient @relation(fields: [factureId], references: [id], onDelete: Cascade)
  article       Article?      @relation(fields: [articleId], references: [id])

  @@index([factureId])
}

model ReglementClient {
  id              String   @id @default(cuid())
  numero          String   @unique
  factureId       String
  dateReglement   DateTime
  montant         Float    @default(0)
  modePaiement    String   @default("VIREMENT")
  reference       String?
  infoLibre       String?
  notes           String?
  statut          String   @default("ENREGISTRE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  facture         FactureClient @relation(fields: [factureId], references: [id])

  @@index([factureId])
  @@index([statut])
}

model AvoirClient {
  id              String   @id @default(cuid())
  numero          String   @unique
  dateAvoir       DateTime
  clientId        String
  factureId       String?  // Facture d'origine (optionnel)
  motif           String?
  statut          String   @default("BROUILLON")
  notes           String?
  infoLibre       String?
  totalHT         Float    @default(0)
  totalTVA        Float    @default(0)
  totalTTC        Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Tiers              @relation(fields: [clientId], references: [id])
  facture         FactureClient?     @relation(fields: [factureId], references: [id])
  lignes          LigneAvoirClient[]

  @@index([clientId])
  @@index([statut])
  @@index([factureId])
}

model LigneAvoirClient {
  id            String   @id @default(cuid())
  avoirId       String
  articleId     String?
  designation   String
  quantite      Float    @default(0)
  prixUnitaire  Float    @default(0)
  tauxTVA       Float    @default(20)
  totalHT       Float    @default(0)

  avoir         AvoirClient @relation(fields: [avoirId], references: [id], onDelete: Cascade)
  article       Article?    @relation(fields: [articleId], references: [id])

  @@index([avoirId])
}

model FactureFournisseur {
  id              String   @id @default(cuid())
  numeroFacture   String
  fournisseurId   String
  dateFacture     DateTime
  dateEcheance    DateTime
  montantHT       Float    @default(0)
  montantTVA      Float    @default(0)
  montantTTC      Float    @default(0)
  statut          String   @default("ENREGISTREE")
  infoLibre       String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fournisseur     Tiers                 @relation(fields: [fournisseurId], references: [id])
  reglements      ReglementFournisseur[]

  @@index([fournisseurId])
  @@index([statut])
}

model ReglementFournisseur {
  id              String   @id @default(cuid())
  factureId       String
  dateReglement   DateTime
  montant         Float    @default(0)
  modePaiement    String   @default("VIREMENT")
  reference       String?
  infoLibre       String?
  notes           String?
  statut          String   @default("ENREGISTRE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  facture         FactureFournisseur @relation(fields: [factureId], references: [id])

  @@index([factureId])
  @@index([statut])
}

model BonLivraison {
  id              String   @id @default(cuid())
  numero          String   @unique
  dateBL          DateTime
  clientId        String
  bonCommande     String?  // Numéro de bon de commande client
  statut          String   @default("BROUILLON")
  infoLibre       String?
  notesLivraison  String?
  totalHT         Float    @default(0)
  factureId       String?  // ID de la facture si le BL a été converti
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Tiers               @relation(fields: [clientId], references: [id])
  lignes          LigneBonLivraison[]
  facture         FactureClient?      @relation(fields: [factureId], references: [id])

  @@index([clientId])
  @@index([statut])
  @@index([factureId])
}

model LigneBonLivraison {
  id              String   @id @default(cuid())
  bonLivraisonId  String
  articleId       String?
  designation     String
  quantite        Float    @default(0)
  prixUnitaire    Float    @default(0)
  totalHT         Float    @default(0)

  bonLivraison    BonLivraison @relation(fields: [bonLivraisonId], references: [id], onDelete: Cascade)
  article         Article?     @relation(fields: [articleId], references: [id])

  @@index([bonLivraisonId])
}

model Parametres {
  id                    String   @id @default(cuid())
  nomEntreprise         String   @default("")
  adresseEntreprise     String?
  villeEntreprise       String?
  telephoneEntreprise   String?
  emailEntreprise       String?
  ice                   String?
  rc                    String?
  rcLieu                String?
  if                    String?
  tp                    String?
  cnss                  String?
  infoLibre             String?
  tvaDefaut             Float    @default(20)
  prefixeFacture        String?
  numeroFactureDepart   Int?
  prefixeBL             String?
  numeroBLDepart        Int?
  prefixeAvoir          String?
  numeroAvoirDepart     Int?
  letterheadImage       String?  // Base64 image du papier à en-tête
  printLayout           String?  // JSON string - Configuration des positions des éléments
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
